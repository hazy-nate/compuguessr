          "question": "Which registers are modified by these instructions?",
          "type": "multiple_response",
          "points": 25,
          "responses": [
            {
              "id": 1,
              "text": "rbp"
            },
            {
              "id": 2,
              "text": "rsp"
            },
            {
              "id": 3,
              "text": "rax"
            }
          ]
        }
      ]
