{
  "version": "1.1",
  "challenges": [
    {
      "id": "instruction_001",
      "type": "instruction",
      "difficulty": "easy",
      "title": "Hello, world!",
      "description": "Basic syscalls.",
      "codeblock": [
        "section .data",
        "msg     db \"Hello, world!\"",
        "len     equ $ - msg",
        "",
        "section .text",
        "global _start",
        "",
        "_start:",
        "    mov rax, 1      ; sys_write",
        "    mov rdi, 1      ; stdout",
        "    mov rsi, msg    ; buffer",
        "    mov rdx, len    ; count",
        "    syscall",
        "",
        "    mov rax, 60     ; sys_exit",
        "    xor rdi, rdi    ; exit code 0",
        "    syscall"
      ],
      "questions": [
        {
          "id": 1,
          "question": "What is the output?",
          "type": "text",
          "points": 25
        },
        {
          "id": 2,
          "question": "What platform?",
          "type": "multiple_response",
          "points": 25,
          "responses": [
            {
              "id": 1,
              "text": "Windows"
            },
            {
              "id": 2,
              "text": "Linux"
            }
          ]
        }
      ]
    },
    {
      "id": "instruction_002",
      "type": "instruction",
      "difficulty": "easy",
      "title": "Zero Out",
      "description": "Analyze this common optimization technique.",
      "codeblock": [
        "xor rax, rax",
        "ret"
      ],
      "questions": [
        {
          "id": 1,
          "question": "What will be the value of the rax register after the first instruction?",
          "type": "text",
          "points": 25
        },
        {
          "id": 2,
          "question": "Why is this technique preferred over 'mov rax, 0'?",
          "type": "multiple_choice",
          "points": 25,
          "responses": [
            {
              "id": 1,
              "text": "It is a shorter instruction (fewer bytes)."
            },
            {
              "id": 2,
              "text": "It sets the ZF (Zero Flag)."
            },
            {
              "id": 3,
              "text": "Both of the above."
            }
          ]
        }
      ]
    },
    {
      "id": "instruction_003",
      "type": "instruction",
      "difficulty": "medium",
