{
  "id": "instruction_001",
  "type": "instruction",
  "difficulty": "easy",
  "title": "Hello, world!",
  "description": "Basic syscalls.",
  "codeblock": [
    "section .data",
    "msg     db \"Hello, world!\"",
    "len     equ $ - msg",
    "",
    "section .text",
    "global _start",
    "",
    "_start:",
    "    mov rax, 1      ; sys_write",
    "    mov rdi, 1      ; stdout",
    "    mov rsi, msg    ; buffer",
    "    mov rdx, len    ; count",
    "    syscall",
    "",
    "    mov rax, 60     ; sys_exit",
    "    xor rdi, rdi    ; exit code 0",
    "    syscall"
  ],
  "questions": [
    {
      "id": 1,
      "question": "What is the output?",
      "type": "text",
      "points": 25,
      "answer": {
        "type": "text",
        "value": "Hello, world!",
        "explanation": "The rax=1 syscall is 'sys_write', which prints our string to STDOUT."
      }
    },
    {
      "id": 2,
      "question": "What platform?",
      "type": "multiple_response",
      "points": 25,
      "responses": [
        {
          "id": 1,
          "text": "Windows",
          "explanation": "Incorrect. Windows uses the NT kernel API, not Linux syscall numbers."
        },
        {
          "id": 2,
          "text": "Linux",
          "explanation": "Correct. Syscalls 1 (write) and 60 (exit) match the x86_64 Linux ABI."
        }
      ],
      "answer": { "type": "bitmask", "value": 2 }
    }
  ]
}
